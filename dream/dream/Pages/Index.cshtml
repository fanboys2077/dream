@page
@model IndexModel
@using System.Text.Json
@{
    ViewData["Title"] = "珂珂小皇帝";

    var jsonOptions = new JsonSerializerOptions
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase
    };

    var row1 = Model.Photos.Where(p => p.RowIndex == 0).OrderBy(p => p.Order).ToList();
    var row2 = Model.Photos.Where(p => p.RowIndex == 1).OrderBy(p => p.Order).ToList();
    var row3 = Model.Photos.Where(p => p.RowIndex == 2).OrderBy(p => p.Order).ToList();
}

<div id="lockScreen" class="lock-screen">
    <div class="lock-content">
        <div class="lock-title">珂珂小皇帝</div>
        <div class="lock-hint">↑ 上滑进入</div>
    </div>
</div>

<div class="home-page">
    @Html.AntiForgeryToken()

    <header class="topbar">
        <div class="logo">珂珂小皇帝</div>

        @if (Model.IsLoggedIn)
        {
            <form method="post" asp-page-handler="Logout" class="logout-form">
                <button type="submit" class="login-btn">登出</button>
            </form>
        }
        else
        {
            <button type="button" class="login-btn" id="openLoginBtn">登入</button>
        }
    </header>

    <div id="galleryView">
        <div id="uploadPanel" class="upload-panel @(Model.IsLoggedIn ? "" : "hidden")">
            <button type="button" class="upload-btn" id="uploadBtn">新增图片到照片墙</button>
            <button type="button" class="delete-btn" id="deleteBtn">删除墙上照片</button>
            <input type="file" id="uploadInput" accept="image/*" multiple hidden />
        </div>

        @if (Model.HasImages)
        {
            <main class="hero-section gallery-mode">
                <section class="photo-wall-section centered-wall">
                    <div class="photo-row row-left">
                        <div class="photo-track" id="row1Track"></div>
                    </div>

                    <div class="photo-row row-right">
                        <div class="photo-track" id="row2Track"></div>
                    </div>

                    <div class="photo-row row-left">
                        <div class="photo-track" id="row3Track"></div>
                    </div>
                </section>
            </main>
        }
        else
        {
            <main class="hero-section empty-mode" id="heroSection">
                <div class="center-box">
                    <p class="empty-text">目前没有任何照片</p>
                </div>
            </main>
        }
    </div>

    <div id="loginView" class="login-view hidden">
        <div class="login-screen">
            <div class="login-panel">
                <div class="moon"></div>

                <form class="login-form" id="loginForm">
                    <div class="form-center-group">
                        <div class="input-group">
                            <span class="input-icon">👤</span>
                            <input type="text" id="username" placeholder="Username" />
                        </div>

                        <div class="input-group">
                            <span class="input-icon">🔒</span>
                            <input type="password" id="password" placeholder="Password" />
                        </div>

                        <button type="submit" class="login-submit">LOGIN</button>
                    </div>

                    <div class="bottom-info">
                        <div class="welcome-title">恭迎陛下</div>
                        <div class="welcome-subtitle">请输入帐号密码</div>
                        <button type="button" class="back-btn" id="backToGalleryBtn">返回照片墙</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div id="lightbox" class="lightbox" onclick="closeLightbox(event)">
    <span class="lightbox-close" onclick="closeLightbox(event)">×</span>
    <img id="lightboxImage" class="lightbox-content" src="" alt="大图预览" />
</div>

<div id="cropModal" class="crop-modal hidden">
    <div class="crop-panel">
        <div class="crop-title">选择照片显示区域</div>

        <div class="crop-body">
            <div class="crop-editor" id="cropEditor">
                <div class="crop-image-stage" id="cropFrame">
                    <img id="cropImage" class="crop-preview-image" src="" alt="裁切预览" />
                    <div class="crop-selection-box"></div>
                </div>
            </div>

            <div class="crop-controls">
                <div class="crop-file-label">
                    第 <span id="cropCurrentIndex">1</span> / <span id="cropTotalCount">1</span> 张
                </div>

                <label class="crop-label">缩放</label>
                <input type="range" id="zoomRange" min="1" max="4" step="0.01" value="1" />

                <div class="crop-tip">
                    直接拖曳左侧图片，调整在照片墙卡片中要显示的区域
                </div>

                <div class="crop-actions">
                    <button type="button" id="cropPrevBtn" class="crop-btn">上一张</button>
                    <button type="button" id="cropNextBtn" class="crop-btn primary">下一张</button>
                    <button type="button" id="cropFinishBtn" class="crop-btn finish">完成加入</button>
                    <button type="button" id="cropCancelBtn" class="crop-btn">取消</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const lockScreen = document.getElementById("lockScreen");
    const galleryView = document.getElementById("galleryView");
    const loginView = document.getElementById("loginView");
    const openLoginBtn = document.getElementById("openLoginBtn");
    const backToGalleryBtn = document.getElementById("backToGalleryBtn");
    const loginForm = document.getElementById("loginForm");
    const uploadPanel = document.getElementById("uploadPanel");
    const uploadBtn = document.getElementById("uploadBtn");
    const deleteBtn = document.getElementById("deleteBtn");
    const uploadInput = document.getElementById("uploadInput");
    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

    const cropModal = document.getElementById("cropModal");
    const cropImage = document.getElementById("cropImage");
    const cropFrame = document.getElementById("cropFrame");
    const zoomRange = document.getElementById("zoomRange");
    const cropPrevBtn = document.getElementById("cropPrevBtn");
    const cropNextBtn = document.getElementById("cropNextBtn");
    const cropFinishBtn = document.getElementById("cropFinishBtn");
    const cropCancelBtn = document.getElementById("cropCancelBtn");
    const cropCurrentIndex = document.getElementById("cropCurrentIndex");
    const cropTotalCount = document.getElementById("cropTotalCount");

    const cropCanvas = document.createElement("canvas");
    cropCanvas.width = 260;
    cropCanvas.height = 160;
    const cropCtx = cropCanvas.getContext("2d");

    let cropImageNaturalWidth = 0;
    let cropImageNaturalHeight = 0;
    let cropBaseWidth = 0;
    let cropBaseHeight = 0;
    let cropMinScale = 1;
    const selectionBoxWidth = 260;
    const selectionBoxHeight = 160;

    let row1Images = @Html.Raw(JsonSerializer.Serialize(row1, jsonOptions));
    let row2Images = @Html.Raw(JsonSerializer.Serialize(row2, jsonOptions));
    let row3Images = @Html.Raw(JsonSerializer.Serialize(row3, jsonOptions));

    let deleteMode = false;
    let selectedImages = new Set();

    let pendingUploadFiles = [];
    let pendingUploadLayouts = [];
    let currentCropIndex = 0;

    let cropState = {
        scale: 1,
        offsetX: 0,
        offsetY: 0,
        dragging: false,
        startX: 0,
        startY: 0
    };

    function getAllCurrentPhotos() {
        return [...row1Images, ...row2Images, ...row3Images];
    }

    function splitPhotosIntoRows(photos) {
        const sorted = [...photos].sort((a, b) => {
            if (a.rowIndex !== b.rowIndex) return a.rowIndex - b.rowIndex;
            return a.order - b.order;
        });

        row1Images = sorted.filter(p => p.rowIndex === 0);
        row2Images = sorted.filter(p => p.rowIndex === 1);
        row3Images = sorted.filter(p => p.rowIndex === 2);
    }

    function ensureGalleryStructure() {
        let heroSection = document.querySelector(".hero-section");
        const hasWall = document.querySelector(".photo-wall-section");

        if (hasWall) return;

        if (!heroSection) {
            heroSection = document.createElement("main");
            heroSection.className = "hero-section gallery-mode";
            galleryView.appendChild(heroSection);
        } else {
            heroSection.className = "hero-section gallery-mode";
        }

        heroSection.innerHTML = `
            <section class="photo-wall-section centered-wall">
                <div class="photo-row row-left">
                    <div class="photo-track" id="row1Track"></div>
                </div>
                <div class="photo-row row-right">
                    <div class="photo-track" id="row2Track"></div>
                </div>
                <div class="photo-row row-left">
                    <div class="photo-track" id="row3Track"></div>
                </div>
            </section>
        `;
    }

    function renderTrack(trackId, photos) {
        const track = document.getElementById(trackId);
        if (!track) return;

        track.innerHTML = "";

        if (!photos || photos.length === 0) return;

        [...photos, ...photos].forEach((photo, index) => {
            const card = document.createElement("div");
            card.className = "photo-card";

            if (selectedImages.has(photo.url)) {
                card.classList.add("selected-for-delete");
            }

            const frame = document.createElement("div");
            frame.className = "photo-card-frame";

            const image = document.createElement("img");
            image.alt = "photo";
            image.draggable = false;
            image.dataset.imageUrl = photo.url;
            image.dataset.duplicateIndex = index;
            image.className = "photo-card-image";

            image.onclick = function (event) {
                event.stopPropagation();

                if (deleteMode) {
                    toggleSelectImage(photo.url);
                } else {
                    openLightbox(photo.url);
                }
            };

            image.src = photo.previewUrl || photo.url;

            frame.appendChild(image);
            card.appendChild(frame);
            track.appendChild(card);
        });
    }

    

    function renderAllTracks() {
        ensureGalleryStructure();
        renderTrack("row1Track", row1Images);
        renderTrack("row2Track", row2Images);
        renderTrack("row3Track", row3Images);
    }

    function toggleSelectImage(imageUrl) {
        if (selectedImages.has(imageUrl)) {
            selectedImages.delete(imageUrl);
        } else {
            selectedImages.add(imageUrl);
        }

        renderAllTracks();
    }

    function enterDeleteMode() {
        deleteMode = true;
        selectedImages.clear();

        if (deleteBtn) {
            deleteBtn.textContent = "确认删除";
            deleteBtn.classList.add("delete-mode");
        }

        const lightbox = document.getElementById("lightbox");
        lightbox.classList.remove("show");
        document.body.style.overflow = "";

        renderAllTracks();
    }

    function exitDeleteMode() {
        deleteMode = false;
        selectedImages.clear();

        if (deleteBtn) {
            deleteBtn.textContent = "删除墙上照片";
            deleteBtn.classList.remove("delete-mode");
        }

        renderAllTracks();
    }

    async function confirmDeleteSelectedImages() {
        const imagesToDelete = Array.from(selectedImages);

        if (imagesToDelete.length === 0) {
            exitDeleteMode();
            alert("本次删除了 0 张照片");
            return;
        }

        try {
            const response = await fetch("?handler=Delete", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "RequestVerificationToken": token
                },
                body: JSON.stringify({
                    images: imagesToDelete
                })
            });

            const data = await response.json();

            if (!response.ok || !data.success) {
                alert(data.message || "删除失败");
                return;
            }

            splitPhotosIntoRows(data.photos || []);
            exitDeleteMode();
            refreshGalleryEmptyState();

            alert(`本次删除了 ${(data.deletedImages || []).length} 张照片`);
        } catch (error) {
            alert("删除失败，请稍后再试");
            console.error(error);
        }
    }

    function refreshGalleryEmptyState() {
        const allPhotos = getAllCurrentPhotos();
        let heroSection = document.querySelector(".hero-section");

        if (allPhotos.length > 0) {
            renderAllTracks();
            return;
        }

        if (!heroSection) {
            heroSection = document.createElement("main");
            galleryView.appendChild(heroSection);
        }

        heroSection.className = "hero-section empty-mode";
        heroSection.innerHTML = `
            <div class="center-box">
                <p class="empty-text">目前没有任何照片</p>
            </div>
        `;
    }

    function openLightbox(imageSrc) {
        if (deleteMode) return;

        const lightbox = document.getElementById("lightbox");
        const lightboxImage = document.getElementById("lightboxImage");

        lightboxImage.src = imageSrc;
        lightbox.classList.add("show");
        document.body.style.overflow = "hidden";
    }

    function closeLightbox(event) {
        const lightbox = document.getElementById("lightbox");

        if (!event || event.target.id === "lightbox" || event.target.classList.contains("lightbox-close")) {
            lightbox.classList.remove("show");
            document.body.style.overflow = "";
        }
    }

    function unlockScreen() {
        if (!lockScreen || lockScreen.classList.contains("hide")) return;
        lockScreen.classList.add("hide");
    }

    function updateCropImageTransform() {
        if (cropState.scale < cropMinScale) {
            cropState.scale = cropMinScale;
        }

        clampCropOffsets();

        const width = cropBaseWidth * cropState.scale;
        const height = cropBaseHeight * cropState.scale;

        cropImage.style.width = `${width}px`;
        cropImage.style.height = `${height}px`;
        cropImage.style.transform = `translate(calc(-50% + ${cropState.offsetX}px), calc(-50% + ${cropState.offsetY}px))`;
    }

    function initializeCropImageSize() {
        if (!cropImageNaturalWidth || !cropImageNaturalHeight) return;

        const stageWidth = cropFrame.clientWidth;
        const stageHeight = cropFrame.clientHeight;

        const imageRatio = cropImageNaturalWidth / cropImageNaturalHeight;
        const stageRatio = stageWidth / stageHeight;

        if (imageRatio > stageRatio) {
            cropBaseWidth = stageWidth;
            cropBaseHeight = stageWidth / imageRatio;
        } else {
            cropBaseHeight = stageHeight;
            cropBaseWidth = stageHeight * imageRatio;
        }

        const minScaleX = selectionBoxWidth / cropBaseWidth;
        const minScaleY = selectionBoxHeight / cropBaseHeight;

        cropMinScale = Math.max(minScaleX, minScaleY, 0.1);

        zoomRange.min = cropMinScale.toFixed(2);
        if (parseFloat(zoomRange.value) < cropMinScale) {
            zoomRange.value = cropMinScale.toFixed(2);
        }
    }

    function clampCropOffsets() {
        const scaledWidth = cropBaseWidth * cropState.scale;
        const scaledHeight = cropBaseHeight * cropState.scale;

        const maxOffsetX = Math.max(0, (scaledWidth - selectionBoxWidth) / 2);
        const maxOffsetY = Math.max(0, (scaledHeight - selectionBoxHeight) / 2);

        if (cropState.offsetX > maxOffsetX) cropState.offsetX = maxOffsetX;
        if (cropState.offsetX < -maxOffsetX) cropState.offsetX = -maxOffsetX;

        if (cropState.offsetY > maxOffsetY) cropState.offsetY = maxOffsetY;
        if (cropState.offsetY < -maxOffsetY) cropState.offsetY = -maxOffsetY;
    }

    function exportCurrentCropImage() {
        const width = cropBaseWidth * cropState.scale;
        const height = cropBaseHeight * cropState.scale;

        const stageCenterX = cropFrame.clientWidth / 2;
        const stageCenterY = cropFrame.clientHeight / 2;

        const imageLeft = stageCenterX - width / 2 + cropState.offsetX;
        const imageTop = stageCenterY - height / 2 + cropState.offsetY;

        const selectionLeft = stageCenterX - selectionBoxWidth / 2;
        const selectionTop = stageCenterY - selectionBoxHeight / 2;

        const sx = (selectionLeft - imageLeft) * (cropImageNaturalWidth / width);
        const sy = (selectionTop - imageTop) * (cropImageNaturalHeight / height);
        const sWidth = selectionBoxWidth * (cropImageNaturalWidth / width);
        const sHeight = selectionBoxHeight * (cropImageNaturalHeight / height);

        cropCtx.clearRect(0, 0, cropCanvas.width, cropCanvas.height);
        cropCtx.drawImage(
            cropImage,
            sx, sy, sWidth, sHeight,
            0, 0, cropCanvas.width, cropCanvas.height
        );

        return cropCanvas.toDataURL("image/jpeg", 0.95);
    }

        function exportCropPreviewByIndex(index) {
        const item = pendingUploadLayouts[index];
        if (!item || !item.previewUrl) return "";

        const tempImage = new Image();
        tempImage.src = item.previewUrl;

        const canvas = document.createElement("canvas");
        canvas.width = 260;
        canvas.height = 160;
        const ctx = canvas.getContext("2d");

        const naturalWidth = item.originalWidth;
        const naturalHeight = item.originalHeight;

        const cropX = item.cropX;
        const cropY = item.cropY;
        const cropWidth = item.cropWidth;
        const cropHeight = item.cropHeight;

        return new Promise((resolve) => {
            tempImage.onload = function () {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                ctx.drawImage(
                    tempImage,
                    cropX, cropY, cropWidth, cropHeight,
                    0, 0, canvas.width, canvas.height
                );
                resolve(canvas.toDataURL("image/jpeg", 0.95));
            };
        });
    }

    function saveCurrentCropState() {
        if (!pendingUploadLayouts[currentCropIndex]) return;

        const rect = getCurrentCropRect();
        pendingUploadLayouts[currentCropIndex].cropX = rect.cropX;
        pendingUploadLayouts[currentCropIndex].cropY = rect.cropY;
        pendingUploadLayouts[currentCropIndex].cropWidth = rect.cropWidth;
        pendingUploadLayouts[currentCropIndex].cropHeight = rect.cropHeight;
        pendingUploadLayouts[currentCropIndex].originalWidth = rect.originalWidth;
        pendingUploadLayouts[currentCropIndex].originalHeight = rect.originalHeight;
    }

    function getCurrentCropRect() {
        const width = cropBaseWidth * cropState.scale;
        const height = cropBaseHeight * cropState.scale;

        const stageCenterX = cropFrame.clientWidth / 2;
        const stageCenterY = cropFrame.clientHeight / 2;

        const imageLeft = stageCenterX - width / 2 + cropState.offsetX;
        const imageTop = stageCenterY - height / 2 + cropState.offsetY;

        const selectionLeft = stageCenterX - selectionBoxWidth / 2;
        const selectionTop = stageCenterY - selectionBoxHeight / 2;

        const cropX = (selectionLeft - imageLeft) * (cropImageNaturalWidth / width);
        const cropY = (selectionTop - imageTop) * (cropImageNaturalHeight / height);
        const cropWidth = selectionBoxWidth * (cropImageNaturalWidth / width);
        const cropHeight = selectionBoxHeight * (cropImageNaturalHeight / height);

        return {
            cropX: Math.max(0, cropX),
            cropY: Math.max(0, cropY),
            cropWidth: Math.min(cropWidth, cropImageNaturalWidth),
            cropHeight: Math.min(cropHeight, cropImageNaturalHeight),
            originalWidth: cropImageNaturalWidth,
            originalHeight: cropImageNaturalHeight
        };
    }

    function loadCropState(index) {
        const item = pendingUploadLayouts[index];
        if (!item) return;

        cropCurrentIndex.textContent = (index + 1).toString();
        cropTotalCount.textContent = pendingUploadLayouts.length.toString();

        cropImage.onload = function () {
            cropImageNaturalWidth = cropImage.naturalWidth;
            cropImageNaturalHeight = cropImage.naturalHeight;

            initializeCropImageSize();

            cropState.scale = Math.max(item.scale ?? cropMinScale, cropMinScale);
            cropState.offsetX = item.offsetX ?? 0;
            cropState.offsetY = item.offsetY ?? 0;

            zoomRange.value = cropState.scale.toFixed(2);

            updateCropImageTransform();
        };

        cropImage.src = item.previewUrl;
    }

    function openCropModal(files) {
        pendingUploadFiles = files;
        pendingUploadLayouts = files.map(() => ({
            scale: 1,
            offsetX: 0,
            offsetY: 0,
            previewUrl: "",
            cropX: 0,
            cropY: 0,
            cropWidth: 0,
            cropHeight: 0,
            originalWidth: 0,
            originalHeight: 0
        }));

        pendingUploadLayouts.forEach((item, index) => {
            item.previewUrl = URL.createObjectURL(files[index]);
        });

        currentCropIndex = 0;
        cropModal.classList.remove("hidden");
        document.body.style.overflow = "hidden";
        loadCropState(currentCropIndex);
    }

    function closeCropModal() {
        pendingUploadLayouts.forEach(item => {
            if (item.previewUrl) {
                URL.revokeObjectURL(item.previewUrl);
            }
        });

        pendingUploadFiles = [];
        pendingUploadLayouts = [];
        currentCropIndex = 0;

        cropModal.classList.add("hidden");
        document.body.style.overflow = "";
        uploadInput.value = "";
    }

    renderAllTracks();
    refreshGalleryEmptyState();

    let touchStartY = 0;

    document.addEventListener("touchstart", function (e) {
        touchStartY = e.touches[0].clientY;
    });

    document.addEventListener("touchend", function (e) {
        const touchEndY = e.changedTouches[0].clientY;
        if (touchStartY - touchEndY > 80) {
            unlockScreen();
        }
    });

    document.addEventListener("wheel", function (e) {
        if (e.deltaY < -30) {
            unlockScreen();
        }
    });

    if (lockScreen) {
        lockScreen.addEventListener("click", function () {
            unlockScreen();
        });
    }

    if (openLoginBtn) {
        openLoginBtn.addEventListener("click", function () {
            galleryView.classList.add("hidden");
            loginView.classList.remove("hidden");
        });
    }

    if (backToGalleryBtn) {
        backToGalleryBtn.addEventListener("click", function () {
            loginView.classList.add("hidden");
            galleryView.classList.remove("hidden");
        });
    }

    if (loginForm) {
        loginForm.addEventListener("submit", async function (event) {
            event.preventDefault();

            const username = document.getElementById("username").value.trim();
            const password = document.getElementById("password").value.trim();

            if (!username || !password) {
                alert("请输入帐号与密码");
                return;
            }

            try {
                const response = await fetch("?handler=Login", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "RequestVerificationToken": token
                    },
                    body: JSON.stringify({
                        username: username,
                        password: password
                    })
                });

                const data = await response.json();

                if (data.success) {
                    alert("登入成功，欢迎陛下");

                    loginView.classList.add("hidden");
                    galleryView.classList.remove("hidden");
                    uploadPanel.classList.remove("hidden");

                    if (openLoginBtn) {
                        openLoginBtn.textContent = "已登入";
                        openLoginBtn.disabled = true;
                        openLoginBtn.style.opacity = "0.65";
                        openLoginBtn.style.cursor = "default";
                    }
                } else {
                    alert(data.message || "帐号或密码错误");
                }
            } catch (error) {
                alert("登入失败，请稍后再试");
                console.error(error);
            }
        });
    }

    if (uploadBtn) {
        uploadBtn.addEventListener("click", function () {
            uploadInput.click();
        });
    }

    if (deleteBtn) {
        deleteBtn.addEventListener("click", async function () {
            if (!deleteMode) {
                enterDeleteMode();
            } else {
                await confirmDeleteSelectedImages();
            }
        });
    }

    if (uploadInput) {
        uploadInput.addEventListener("change", function (event) {
            const files = Array.from(event.target.files || []);
            if (files.length === 0) return;

            openCropModal(files);
        });
    }

    if (cropFrame) {
        cropFrame.addEventListener("mousedown", function (e) {
            cropState.dragging = true;
            cropState.startX = e.clientX;
            cropState.startY = e.clientY;
        });
    }

    document.addEventListener("mousemove", function (e) {
        if (!cropState.dragging) return;

        const dx = e.clientX - cropState.startX;
        const dy = e.clientY - cropState.startY;

        cropState.offsetX += dx;
        cropState.offsetY += dy;

        cropState.startX = e.clientX;
        cropState.startY = e.clientY;

        updateCropImageTransform();
    });

    document.addEventListener("mouseup", function () {
        if (!cropState.dragging) return;
        cropState.dragging = false;
        pendingUploadLayouts[currentCropIndex].scale = cropState.scale;
        pendingUploadLayouts[currentCropIndex].offsetX = cropState.offsetX;
        pendingUploadLayouts[currentCropIndex].offsetY = cropState.offsetY;
        saveCurrentCropState();
    });

    if (zoomRange) {
        zoomRange.addEventListener("input", function () {
            cropState.scale = Math.max(parseFloat(zoomRange.value), cropMinScale);
            zoomRange.value = cropState.scale.toFixed(2);
            updateCropImageTransform();

            pendingUploadLayouts[currentCropIndex].scale = cropState.scale;
            pendingUploadLayouts[currentCropIndex].offsetX = cropState.offsetX;
            pendingUploadLayouts[currentCropIndex].offsetY = cropState.offsetY;
            saveCurrentCropState();
        });
    }

    if (cropPrevBtn) {
        cropPrevBtn.addEventListener("click", function () {
            pendingUploadLayouts[currentCropIndex].scale = cropState.scale;
            pendingUploadLayouts[currentCropIndex].offsetX = cropState.offsetX;
            pendingUploadLayouts[currentCropIndex].offsetY = cropState.offsetY;
            saveCurrentCropState();

            if (currentCropIndex > 0) {
                currentCropIndex--;
                loadCropState(currentCropIndex);
            }
        });
    }

    if (cropNextBtn) {
        cropNextBtn.addEventListener("click", function () {
            pendingUploadLayouts[currentCropIndex].scale = cropState.scale;
            pendingUploadLayouts[currentCropIndex].offsetX = cropState.offsetX;
            pendingUploadLayouts[currentCropIndex].offsetY = cropState.offsetY;
            saveCurrentCropState();

            if (currentCropIndex < pendingUploadFiles.length - 1) {
                currentCropIndex++;
                loadCropState(currentCropIndex);
            }
        });
    }

    if (cropCancelBtn) {
        cropCancelBtn.addEventListener("click", function () {
            closeCropModal();
        });
    }

    if (cropFinishBtn) {
        cropFinishBtn.addEventListener("click", async function () {
            pendingUploadLayouts[currentCropIndex].scale = cropState.scale;
            pendingUploadLayouts[currentCropIndex].offsetX = cropState.offsetX;
            pendingUploadLayouts[currentCropIndex].offsetY = cropState.offsetY;
            saveCurrentCropState();

            const formData = new FormData();

            for (let i = 0; i < pendingUploadFiles.length; i++) {
                formData.append("files", pendingUploadFiles[i]);

                const previewDataUrl = await exportCropPreviewByIndex(i);
                const previewBlob = await (await fetch(previewDataUrl)).blob();
                const previewFile = new File(
                    [previewBlob],
                    `preview_${i}.jpg`,
                    { type: "image/jpeg" }
                );

            formData.append("previewFiles", previewFile);
    }

            formData.append("layoutJson", JSON.stringify(
                pendingUploadLayouts.map(item => ({
                    cropX: item.cropX,
                    cropY: item.cropY,
                    cropWidth: item.cropWidth,
                    cropHeight: item.cropHeight,
                    originalWidth: item.originalWidth,
                    originalHeight: item.originalHeight,
                    renderWidth: 260,
                    renderHeight: 160
                }))
            ));

            try {
                const response = await fetch("?handler=Upload", {
                    method: "POST",
                    headers: {
                        "RequestVerificationToken": token
                    },
                    body: formData
                });

                const data = await response.json();

                if (!response.ok || !data.success) {
                    alert(data.message || "上传失败");
                    return;
                }

                splitPhotosIntoRows(data.photos || []);
                closeCropModal();
                refreshGalleryEmptyState();
                alert("图片已成功加入照片墙");
            } catch (error) {
                alert("上传失败，请稍后再试");
                console.error(error);
            }
        });
    }

    document.addEventListener("keydown", function (event) {
        if (event.key === "Escape") {
            if (!cropModal.classList.contains("hidden")) {
                closeCropModal();
                return;
            }

            const lightbox = document.getElementById("lightbox");
            if (lightbox.classList.contains("show")) {
                lightbox.classList.remove("show");
                document.body.style.overflow = "";
            }

            if (deleteMode) {
                exitDeleteMode();
            }
        }
    });

</script>